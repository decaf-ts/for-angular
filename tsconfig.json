/* To learn more about this file see: https://angular.io/config/tsconfig. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "strictPropertyInitialization": true, // default true
    "skipLibCheck": true,
    "noImplicitReturns": false, // default true
    "baseUrl": "./",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "downlevelIteration": true,
    "outDir": "./dist/out-tsc",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "resolveJsonModule": true,
    "noFallthroughCasesInSwitch": true,
    "sourceMap": true,
    "declaration": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "typeRoots": ["node_modules/@types"],
    "target": "es2022",
    "module": "es2020",
    "lib": ["es2018", "DOM"],
    "useDefineForClassFields": false,
    "paths": {
      "@decaf-ts/core": ["./node_modules/@decaf-ts/core/lib"],
      "@decaf-ts/core/*": ["./node_modules/@decaf-ts/core/lib/*"],
      "@decaf-ts/core/ram": ["./node_modules/@decaf-ts/core/lib/ram"],
      "@decaf-ts/overrides/ui-decorators": [
        "./node_modules/@decaf-ts/ui-decorators/lib/esm/model/overrides.js"
      ]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": false, // default true
    "paths": {
      "@decaf-ts/core": ["./node_modules/@decaf-ts/core/lib"],
      "@decaf-ts/core/*": ["./node_modules/@decaf-ts/core/lib/*"],
      "@decaf-ts/core/ram": ["./node_modules/@decaf-ts/core/lib/ram"],
      "@decaf-ts/overrides/ui-decorators": [
        "./node_modules/@decaf-ts/ui-decorators/lib/esm/model/overrides.js"
      ]
    }
  }
}
